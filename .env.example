# Clever Dent AI Monorepo — environment reference
# Copy per-app env files from apps/*/.env.example

# ai-orchestrator: apps/ai-orchestrator/.env (PORT=4000)
# homepage-platform: apps/homepage-platform/.env (PORT=3002)
# public-site: apps/public-site/.env (port 3000 via Next.js)

# Infra (docker compose -f infra/docker-compose.yml up -d)
# postgres-ai: localhost:5433
# postgres-hp: localhost:5434
# redis: localhost:6380
