# Server
PORT=4000
NODE_ENV=development

# AI Gateway (OpenAI-compatible)
AI_GATEWAY_URL=https://api.openai.com/v1
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_MS=30000
AI_RESPONSE_DELAY_MS=5000

# Redis (Phase 7 — optional)
# Internal server: app on host connects via localhost; Redis is NOT exposed to LAN
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# PostgreSQL (Phase A)
# Internal server: app on host uses localhost; port 5433 is exposed to LAN for DB tools
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_orchestrator

# Internal server: set NODE_ENV=production, change POSTGRES_PASSWORD, PORT=4000
# See docs/deploy-internal-server.md

# pgAdmin (Future Phase A — optional)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
