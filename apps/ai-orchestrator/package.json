{
  "name": "ai-orchestrator",
  "version": "1.0.0",
  "description": "AI Integration PoC Architecture (F6)",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop ai-orchestrator",
    "restart:pm2": "pm2 restart ai-orchestrator",
    "logs:pm2": "pm2 logs ai-orchestrator",
    "dev": "tsx watch src/server.ts",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@clever-dent/shared-contracts": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "postgres": "^3.4.9",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
